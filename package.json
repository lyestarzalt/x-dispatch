{
  "name": "x-dispatch",
  "productName": "X-Dispatch",
  "version": "1.3.1",
  "description": "Flight dispatch, airport visualization, and addon management for X-Plane 12",
  "author": {
    "name": "Lyes Tarzalt"
  },
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lyestarzalt/x-dispatch"
  },
  "homepage": "https://github.com/lyestarzalt/x-dispatch#readme",
  "keywords": [
    "x-plane",
    "x-plane-12",
    "flight-simulator",
    "flight-planning",
    "flight-dispatch",
    "airport",
    "aviation",
    "addon-manager",
    "simbrief",
    "vatsim",
    "electron",
    "maplibre"
  ],
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "prepare": "husky",
    "test:xplane": "npx tsx scripts/test-xplane-websocket.ts"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
    "@electron-forge/maker-deb": "^7.8.0",
    "@electron-forge/maker-rpm": "^7.8.0",
    "@electron-forge/maker-squirrel": "^7.8.0",
    "@electron-forge/maker-zip": "^7.8.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.0",
    "@electron-forge/plugin-fuses": "^7.8.0",
    "@electron-forge/plugin-vite": "^7.8.0",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^2.1.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/electron-window-state": "^5.0.2",
    "@types/node": "^25.3.3",
    "@types/node-7z": "^2.1.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@types/suncalc": "^1.9.2",
    "@types/tz-lookup": "^6.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.6.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "src/lib/db/schema.ts": [
      "bash -c 'npx drizzle-kit generate --name auto-$(date +%Y%m%d%H%M%S) && git add drizzle/'",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.10",
    "@deck.gl/layers": "^9.2.10",
    "@deck.gl/mapbox": "^9.2.10",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/electron": "^7.9.0",
    "@sentry/react": "^10.41.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tanstack/react-query": "^5.90.21",
    "@types/yauzl": "^2.10.3",
    "7zip-bin": "^5.2.0",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "crc-32": "^1.2.2",
    "drizzle-orm": "^0.45.1",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-window-state": "^5.0.3",
    "i18next": "^25.8.13",
    "lucide-react": "^0.576.0",
    "maplibre-gl": "^5.19.0",
    "metar-taf-parser": "^9.1.2",
    "node-7z": "^3.0.0",
    "node-unrar-js": "^2.0.2",
    "react-i18next": "^16.5.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.0",
    "suncalc": "^1.9.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tz-lookup": "^6.1.25",
    "update-electron-app": "^3.1.2",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.19.0",
    "yauzl": "^3.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  }
}
